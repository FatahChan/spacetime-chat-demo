{
  "name": "my-spacetime-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "PORT=4000 node .output/server/index.mjs",
    "spacetime:generate": "spacetime generate --lang typescript --out-dir src/module_bindings --module-path spacetimedb",
    "spacetime:publish:local": "spacetime publish my-spacetime-app-6ali9 --module-path spacetimedb --server local",
    "spacetime:publish": "spacetime publish my-spacetime-app-6ali9 --module-path spacetimedb --server maincloud",
    "spacetime:publish:clear": "spacetime publish my-spacetime-app-6ali9 --module-path spacetimedb --server maincloud --delete-data -y"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "@tanstack/react-router": "^1.162.0",
    "@tanstack/react-router-devtools": "^1.162.0",
    "@tanstack/react-router-ssr-query": "^1.162.0",
    "@tanstack/react-start": "^1.162.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-oidc-context": "^3.3.0",
    "spacetimedb": "^2.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.2",
    "vite": "^7.1.5",
    "vite-tsconfig-paths": "^5.1.4"
  }
}